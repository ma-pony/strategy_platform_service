# 应用运行环境，可选值：development | test | production
APP_ENV=development

# 日志级别，可选值：DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 应用名称
APP_NAME=strategy_platform_service

# PostgreSQL 异步连接（Web 层使用）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cryptotrader?ssl=disable

# PostgreSQL 同步连接（Alembic 迁移和 sqladmin 使用）
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/cryptotrader

# Redis 连接（Celery broker + 信号缓存）
REDIS_URL=redis://localhost:6379/0

# JWT 签名密钥（生产环境请使用强随机字符串）
SECRET_KEY=your_secret_key_here

# sqladmin 管理员凭证
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
